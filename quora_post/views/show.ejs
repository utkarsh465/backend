<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Post</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1 class="quora">Quora</h1>
    
    <div class="posts-container">
        <div class="post">
            <span class="user">@<%= post.username %></span>
            <p class="content"><%= post.content %></p>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-top: 1rem;">Post ID: <%= post.id %></p>
        </div>
        
        <div style="margin-top: 1.5rem;">
            <form action="/posts" method="get">
                <button type="submit" style="background-color: #282829;">Back to Feed</button>
            </form>
        </div>
    </div>
</body>

</html>