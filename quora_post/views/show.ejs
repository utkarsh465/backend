<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>fetch post by id</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1>fetch post by id</h1>
    

    <div class="post">
        <p>post id: <%= post.id %></p>
        <h3>@<%= post.username %></h3>
        <h4><%= post.content %></h4>
    </div>
</body>

</html>